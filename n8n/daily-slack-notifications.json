{
  "name": "AI Learning Coach — Daily Slack Push",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 11 * * *"
            }
          ]
        }
      },
      "id": "a1b2c3d4-0001-4001-8001-000000000001",
      "name": "Daily 11am ET",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        420,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://learning-agent-pearl.vercel.app/api/notifications/daily",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-notify-secret",
              "value": "REPLACE_WITH_CRON_SECRET"
            }
          ]
        },
        "options": {
          "timeout": 60000
        }
      },
      "id": "a1b2c3d4-0002-4002-8002-000000000002",
      "name": "Send daily Slack DMs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        660,
        300
      ]
    }
  ],
  "connections": {
    "Daily 11am ET": {
      "main": [
        [
          {
            "node": "Send daily Slack DMs",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "timezone": "America/New_York",
    "executionOrder": "v1"
  },
  "active": false
}

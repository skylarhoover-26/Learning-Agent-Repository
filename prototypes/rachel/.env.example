# ── Anthropic ──────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Slack ───────────────────────────────────────────────
# Get from: https://api.slack.com/apps → Your App → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
# Get from: Basic Information → App Credentials
SLACK_SIGNING_SECRET=your_slack_signing_secret_here
# Get from: Basic Information → App-Level Tokens
SLACK_APP_TOKEN=xapp-your-app-token-here

# ── Supabase ────────────────────────────────────────────
# Get from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Okta ────────────────────────────────────────────────
# Get from: Okta Admin Console → Applications → Your App
OKTA_CLIENT_ID=your_okta_client_id_here
OKTA_CLIENT_SECRET=your_okta_client_secret_here
OKTA_ISSUER=https://your-org.okta.com/oauth2/default

# ── NextAuth ────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
# Set to your Vercel deployment URL once deployed
NEXTAUTH_URL=http://localhost:3000

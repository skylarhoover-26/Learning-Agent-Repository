# Postgres connection string (Neon, Supabase, Vercel Postgres, etc.)
DATABASE_URL="postgresql://user:pass@host:5432/aiacademy"

# Anthropic API key for the curator
ANTHROPIC_API_KEY="sk-ant-..."

# Slack incoming-webhook URL for approver notifications
SLACK_APPROVERS_WEBHOOK_URL="https://hooks.slack.com/services/..."

# Public URL of this app (used in Slack message links)
APP_URL="https://aiacademy.example.com"

# Shared secret Vercel Cron sends as Bearer auth on cron endpoint hits
CRON_SECRET="generate-a-long-random-string"
